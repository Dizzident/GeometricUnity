  <ItemGroup>
    <None Include="..\..\native\build\libgu_cuda_core.so"
          Condition="Exists('..\..\native\build\libgu_cuda_core.so')"
          CopyToOutputDirectory="PreserveNewest"
          Link="libgu_cuda_core.so" />
