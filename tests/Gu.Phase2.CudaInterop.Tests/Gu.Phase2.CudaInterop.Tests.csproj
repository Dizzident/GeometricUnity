  <!-- Copy native library to test output directory if it exists -->
  <ItemGroup>
    <None Include="..\..\native\build\libgu_phase2_cuda.so"
          Condition="Exists('..\..\native\build\libgu_phase2_cuda.so')"
          CopyToOutputDirectory="PreserveNewest"
