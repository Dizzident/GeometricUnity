{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geometricunity.local/schemas/o4-human-physicist-memo-v1.json",
  "title": "O4 human physicist adjudication memo v1",
  "description": "Fail-closed schema for a final, externally human-authored O4 physicist ruling. Validation establishes document shape only; it does not establish scientific correctness, identity, or qualifications.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "templateOnly",
    "documentKind",
    "memoId",
    "issuedAt",
    "reviewer",
    "repositoryBinding",
    "authorshipAttestations",
    "rulings",
    "globalCaveats",
    "signedPayloadSha256",
    "signatureEnvelope"
  ],
  "properties": {
    "schemaId": { "const": "o4-human-physicist-memo-v1" },
    "schemaVersion": { "const": 1 },
    "templateOnly": { "const": false },
    "documentKind": { "const": "final-physicist-ruling" },
    "memoId": {
      "type": "string",
      "pattern": "^o4memo-[0-9]{8}-[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "issuedAt": { "type": "string", "format": "date-time" },
    "reviewer": { "$ref": "#/$defs/reviewer" },
    "repositoryBinding": { "$ref": "#/$defs/repositoryBinding" },
    "authorshipAttestations": { "$ref": "#/$defs/authorshipAttestations" },
    "rulings": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "items": { "$ref": "#/$defs/ruling" },
      "allOf": [
        { "contains": { "properties": { "rulingId": { "const": "O4-F1-INVARIANT-RAYS" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-F1-COLLECTIVE-COORDINATE" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-F1-FP-NORMALIZATION" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-F2-POSITIVE-MODE-IR" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-F3-THETA-HAAR" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-F4-SADDLE-BACKGROUNDS" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-E1-P447-SOFT-FLOOR" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-E2-P453-UNIFORM-LADDER" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-P455-ZERO-MODE" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-P455-SB-MODEL" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-C1-COMPACT-REAL-FORM" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-C2-YHALF-BOOKKEEPING" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 },
        { "contains": { "properties": { "rulingId": { "const": "O4-C3-WS3-MPROBE-SCOPE" } }, "required": ["rulingId"] }, "minContains": 1, "maxContains": 1 }
      ]
    },
    "globalCaveats": { "type": "string" },
    "signedPayloadSha256": {
      "$comment": "SHA-256 of RFC 8785/JCS canonical JSON after removing signatureEnvelope and signedPayloadSha256.",
      "$ref": "#/$defs/sha256"
    },
    "signatureEnvelope": { "$ref": "#/$defs/signatureEnvelope" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$)).+$"
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewerRegistryId", "fullName", "professionalRole", "institution", "qualifications", "persistentIdentifier"],
      "properties": {
        "reviewerRegistryId": { "type": "string", "minLength": 1 },
        "fullName": { "type": "string", "minLength": 1 },
        "professionalRole": {
          "enum": ["theoretical-physicist", "lattice-field-theorist", "mathematical-physicist", "other-qualified-physicist"]
        },
        "institution": { "type": ["string", "null"], "minLength": 1 },
        "qualifications": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "persistentIdentifier": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "repositoryBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commitSha",
        "dossierPath",
        "dossierSha256",
        "coverageManifestPath",
        "coverageManifestSha256",
        "schemaSha256",
        "reviewerRegistryRecordSha256"
      ],
      "properties": {
        "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "dossierPath": { "const": "docs/Phases/Adjudication/O4_CONVENTIONS_REGISTER.md" },
        "dossierSha256": { "$ref": "#/$defs/sha256" },
        "coverageManifestPath": { "const": "scripts/o4_register/o4_exact_coverage_manifest_v1.json" },
        "coverageManifestSha256": { "$ref": "#/$defs/sha256" },
        "schemaSha256": { "$ref": "#/$defs/sha256" },
        "reviewerRegistryRecordSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "authorshipAttestations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "humanAuthoredRulings",
        "machineGeneratedRulings",
        "independentProfessionalJudgment",
        "riskAcceptanceIsNotPhysicistRuling",
        "noPhysicalMassOrGevClaim"
      ],
      "properties": {
        "humanAuthoredRulings": { "const": true },
        "machineGeneratedRulings": { "const": false },
        "independentProfessionalJudgment": { "const": true },
        "riskAcceptanceIsNotPhysicistRuling": { "const": true },
        "noPhysicalMassOrGevClaim": { "const": true }
      }
    },
    "disposition": {
      "enum": ["accept-at-declared-scope", "accept-with-registered-caveats", "reject", "insufficient-basis", "not-applicable"]
    },
    "scopeAssertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mIsSourceDefined", "singletGapOnly", "noNamedScalarIdentification", "noLineageFill", "latticeUnitsOnly"],
      "properties": {
        "mIsSourceDefined": { "const": false },
        "singletGapOnly": { "const": true },
        "noNamedScalarIdentification": { "const": true },
        "noLineageFill": { "const": true },
        "latticeUnitsOnly": { "const": true }
      }
    },
    "ruling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rulingId", "disposition", "selectedOption", "registeredCaveatIds", "rationale", "reviewedArtifactSha256"],
      "properties": {
        "rulingId": {
          "enum": [
            "O4-F1-INVARIANT-RAYS",
            "O4-F1-COLLECTIVE-COORDINATE",
            "O4-F1-FP-NORMALIZATION",
            "O4-F2-POSITIVE-MODE-IR",
            "O4-F3-THETA-HAAR",
            "O4-F4-SADDLE-BACKGROUNDS",
            "O4-E1-P447-SOFT-FLOOR",
            "O4-E2-P453-UNIFORM-LADDER",
            "O4-P455-ZERO-MODE",
            "O4-P455-SB-MODEL",
            "O4-C1-COMPACT-REAL-FORM",
            "O4-C2-YHALF-BOOKKEEPING",
            "O4-C3-WS3-MPROBE-SCOPE"
          ]
        },
        "disposition": { "$ref": "#/$defs/disposition" },
        "selectedOption": { "type": "string" },
        "registeredCaveatIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "DECLARED-SCOPE-ONLY",
              "DIAGNOSTIC-ONLY",
              "NO-CROSS-MEMBER-COMPARISON",
              "NO-RETIRED-OBJECT-REINSTATEMENT",
              "NO-SOURCE-LINEAGE",
              "NO-PHYSICAL-NORMALIZATION",
              "NO-STAGE-B-AUTHORIZATION"
            ]
          }
        },
        "rationale": { "type": "string", "minLength": 1 },
        "reviewedArtifactSha256": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sha256" }
        },
        "scopeAssertions": { "$ref": "#/$defs/scopeAssertions" }
      },
      "allOf": [
        {
          "if": { "properties": { "rulingId": { "const": "O4-F1-INVARIANT-RAYS" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["translation-invariant-rays-valid-at-declared-constant-field-scope", "random-rays-valid-at-declared-diagnostic-scope", "both-declared-scopes", "neither-admissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-F1-COLLECTIVE-COORDINATE" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["gauge-invariant-ray-coordinate-admissible", "diagnostic-only", "inadmissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-F1-FP-NORMALIZATION" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["within-member-only-caveat-sufficient", "cross-member-comparisons-forbidden", "specified-normalization-required", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-F2-POSITIVE-MODE-IR" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["positive-nonzero-subspace-diagnostic-only", "positive-nonzero-subspace-verdict-admissible", "absolute-nonzero-prescription-required", "contour-prescription-required", "none-admissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-F3-THETA-HAAR" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["unit-quaternion-haar-axis-angle-boundary-admissible", "inadmissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-F4-SADDLE-BACKGROUNDS" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["local-diagnostic-only", "projected-loop-calculation-admissible-at-declared-scope", "inadmissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-E1-P447-SOFT-FLOOR" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["default-1e-4-plus-sweep-diagnostic-only", "alternative-floor-required", "no-floor-prescription-admissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-E2-P453-UNIFORM-LADDER" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["uniform-stiffness-required", "mixed-stiffness-allowed-only-with-junction-covariance", "either-at-declared-error-model", "inadmissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-P455-ZERO-MODE" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["Za-symmetric-k0-exclusion", "Zb-soft-floor-k0", "Zc-exact-zero-only", "none-admissible", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-P455-SB-MODEL" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["accept-w430-as-phase455-workbench-only", "diagnostic-only", "reject-w430-model", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-C1-COMPACT-REAL-FORM" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["phase467-direct-so64-arm-discharges-finite-scope", "additional-human-ruling-required", "reject-transfer", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-C2-YHALF-BOOKKEEPING" } }, "required": ["rulingId"] },
          "then": { "properties": { "selectedOption": { "enum": ["accept-phase404-lepton-doublet-normalization-as-bookkeeping-only", "reject-bookkeeping", "defer"] } } }
        },
        {
          "if": { "properties": { "rulingId": { "const": "O4-C3-WS3-MPROBE-SCOPE" } }, "required": ["rulingId"] },
          "then": {
            "properties": { "selectedOption": { "enum": ["accept-labeled-probe-only-no-lineage", "reject-probe-scope", "defer"] } },
            "allOf": [
              {
                "if": { "properties": { "selectedOption": { "const": "accept-labeled-probe-only-no-lineage" } }, "required": ["selectedOption"] },
                "then": { "required": ["scopeAssertions"] }
              }
            ]
          }
        }
      ]
    },
    "signatureEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "signerRegistryId", "signatureArtifactPath", "signatureArtifactSha256"],
      "properties": {
        "mode": { "enum": ["openpgp-detached", "ed25519-detached", "minisign-detached", "witnessed-signed-document"] },
        "signerRegistryId": { "type": "string", "minLength": 1 },
        "publicKeyFingerprint": { "type": "string", "minLength": 1 },
        "signatureArtifactPath": { "$ref": "#/$defs/relativePath" },
        "signatureArtifactSha256": { "$ref": "#/$defs/sha256" },
        "signatureValue": { "type": "string", "minLength": 1 },
        "witnessRegistryId": { "type": "string", "minLength": 1 },
        "witnessAttestationSha256": { "$ref": "#/$defs/sha256" }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "enum": ["openpgp-detached", "ed25519-detached", "minisign-detached"] } }, "required": ["mode"] },
          "then": { "required": ["publicKeyFingerprint", "signatureValue"] }
        },
        {
          "if": { "properties": { "mode": { "const": "witnessed-signed-document" } }, "required": ["mode"] },
          "then": {
            "required": ["witnessRegistryId", "witnessAttestationSha256"],
            "not": { "anyOf": [{ "required": ["signatureValue"] }, { "required": ["publicKeyFingerprint"] }] }
          }
        }
      ]
    }
  }
}
