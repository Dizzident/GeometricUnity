{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geometricunity.local/schemas/internal_vector_boson_source_spectrum_campaign.schema.json",
  "title": "Internal Vector Boson Source Spectrum Campaign",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campaignId",
    "schemaVersion",
    "sourceCandidateTablePath",
    "readinessSpecPath",
    "branchVariantIds",
    "refinementLevels",
    "environmentIds",
    "sourceQuantityIds",
    "missingCellPolicy",
    "identityScope",
    "provenance"
  ],
  "properties": {
    "campaignId": { "type": "string", "minLength": 1 },
    "schemaVersion": { "type": "string", "minLength": 1 },
    "sourceCandidateTablePath": { "type": "string", "minLength": 1 },
    "readinessSpecPath": { "type": "string", "minLength": 1 },
    "branchVariantIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "refinementLevels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "environmentIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sourceQuantityIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "missingCellPolicy": {
      "type": "string",
      "enum": [ "block-missing-cell" ]
    },
    "identityScope": {
      "type": "string",
      "const": "identity-neutral-vector-boson-source-candidates"
    },
    "provenance": { "type": "object" }
  }
}
