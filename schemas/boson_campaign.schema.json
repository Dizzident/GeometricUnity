{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gu://schemas/boson_campaign.schema.json",
  "title": "BosonCampaignSpec",
  "description": "Specification for a boson comparison campaign.",
  "type": "object",
  "required": ["campaignId", "mode"],
  "properties": {
    "campaignId": {
      "type": "string",
      "description": "Unique campaign identifier"
    },
    "mode": {
      "type": "string",
      "description": "Campaign comparison mode",
      "enum": ["InternalTargetProfile", "ExternalAnalogy"]
    },
    "targetProfileIds": {
      "type": "array",
      "description": "Internal target profile IDs for BC1 mode",
      "items": { "type": "string" }
    },
    "externalDescriptorIds": {
      "type": "array",
      "description": "External analogy descriptor IDs for BC2 mode",
      "items": { "type": "string" }
    },
    "minClaimClass": {
      "type": "string",
      "description": "Minimum claim class for candidates to include",
      "enum": [
        "C0_NumericalMode",
        "C1_LocalPersistentMode",
        "C2_BranchStableBosonicCandidate",
        "C3_ObservedStableCandidate",
        "C4_PhysicalAnalogyCandidate",
        "C5_StrongIdentificationCandidate"
      ],
      "default": "C0_NumericalMode"
    },
    "includeDemoted": {
      "type": "boolean",
      "description": "Whether to include demoted candidates in the comparison",
      "default": true
    }
  }
}
