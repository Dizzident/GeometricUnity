{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gu://schemas/phase4/unified_particle_registry.schema.json",
  "title": "UnifiedParticleRegistry",
  "description": "Unified particle registry emitted by the Phase IV registry merge engine.",
  "type": "object",
  "required": [
    "registryVersion",
    "schemaVersion",
    "candidates"
  ],
  "properties": {
    "registryVersion": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unifiedParticleRecord"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "provenance": {
      "type": "object",
      "required": [
        "createdAt"
      ],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "codeRevision": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "object",
            "null"
          ]
        },
        "backend": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "particleClaimDemotion": {
      "type": "object",
      "required": [
        "reason",
        "details",
        "fromClaimClass",
        "toClaimClass"
      ],
      "properties": {
        "reason": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "fromClaimClass": {
          "type": "string"
        },
        "toClaimClass": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "unifiedParticleRecord": {
      "type": "object",
      "required": [
        "particleId",
        "schemaVersion",
        "particleType",
        "primarySourceId",
        "contributingSourceIds",
        "branchVariantSet",
        "backgroundSet",
        "massLikeEnvelope",
        "branchStabilityScore",
        "observationConfidence",
        "comparisonEvidenceScore",
        "claimClass",
        "computedWithUnverifiedGpu",
        "demotions",
        "ambiguityNotes",
        "registryVersion",
        "provenance"
      ],
      "properties": {
        "particleId": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string"
        },
        "particleType": {
          "type": "string",
          "enum": [
            "Boson",
            "Fermion",
            "Interaction"
          ]
        },
        "primarySourceId": {
          "type": "string"
        },
        "contributingSourceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "branchVariantSet": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "backgroundSet": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "chirality": {
          "type": [
            "string",
            "null"
          ]
        },
        "massLikeEnvelope": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 3,
          "maxItems": 3
        },
        "branchStabilityScore": {
          "type": "number"
        },
        "observationConfidence": {
          "type": "number"
        },
        "comparisonEvidenceScore": {
          "type": "number"
        },
        "claimClass": {
          "type": "string"
        },
        "computedWithUnverifiedGpu": {
          "type": "boolean"
        },
        "demotions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/particleClaimDemotion"
          }
        },
        "ambiguityNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "registryVersion": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "additionalProperties": true
    }
  }
}
